# ─────────────────────────────────────────────────────────────────────────────
# .env.vps — Template de variables d'environnement pour le VPS de production
#
# ⚠️  CE FICHIER EST UN TEMPLATE — ne pas utiliser tel quel.
#     Sur le VPS, ce fichier est généré par GitHub Actions depuis les secrets.
#     En local pour tester, copier en `.env` et remplir les valeurs.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=Mibeko
APP_ENV=production
APP_KEY=                          # Remplir avec: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://app.mibeko.benaja-bendo.fr
APP_DOMAIN=app.mibeko.benaja-bendo.fr

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ─── Logs ─────────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# ─── Nightwatch (Laravel Monitoring) ──────────────────────────────────────────
NIGHTWATCH_TOKEN=                 # Token Nightwatch
NIGHTWATCH_REQUEST_SAMPLE_RATE=0.1

# ─── Base de données (Postgres VPS — service existant Ansible) ────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres           # Nom du conteneur Postgres sur le VPS (réseau db_internal)
DB_PORT=5432
DB_DATABASE=mibeko
DB_USERNAME=pguser                # Correspond à postgres_user dans group_vars/vps.yml
DB_PASSWORD=                      # Correspond à postgres_password dans group_vars/vps.yml

# ─── Session / Cache / Queue ──────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.mibeko.benaja-bendo.fr

CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log

# ─── Stockage (MinIO VPS — réseau interne Docker) ────────────────────────────
# Le conteneur MinIO est sur le réseau "proxy" du VPS, accessible via son nom
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=                # Correspond à minio_root_user dans group_vars/vps.yml
AWS_SECRET_ACCESS_KEY=            # Correspond à minio_root_password dans group_vars/vps.yml
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=mibeko
AWS_ENDPOINT=http://minio:9000    # Accès via le réseau Docker interne
AWS_USE_PATH_STYLE_ENDPOINT=true

# ─── IA ───────────────────────────────────────────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=

# ─── Email ────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="contact@mibeko.benaja-bendo.fr"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Firebase ─────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=mibeko-mobile-34c01
FIREBASE_CREDENTIALS_PATH=storage/app/mibeko-mobile-34c01-firebase-adminsdk-fbsvc-570bc4918b.json
FIREBASE_URL=https://fcm.googleapis.com/v1/projects/${FIREBASE_PROJECT_ID}/messages:send

# ─── GitHub Container Registry (pour docker compose pull) ────────────────────
GITHUB_REPOSITORY=mibeko/mibeko-tableau-de-bord
